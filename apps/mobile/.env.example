# OrbitNest — loan_tracker (Expo). Copy to .env and fill in real values.
# Public (client-safe) only — EXPO_PUBLIC_* is bundled into the shipped app.
# NEVER put the service role key here. API_URL is the API ORIGIN.
EXPO_PUBLIC_ORBITNEST_API_URL=https://api.orbitnest.io
EXPO_PUBLIC_ORBITNEST_PROJECT_SLUG=loan_tracker
EXPO_PUBLIC_ORBITNEST_ANON_KEY=

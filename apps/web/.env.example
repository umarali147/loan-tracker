# OrbitNest — loan_tracker (Next.js). Copy to .env.local and fill in real values.
# Public (client-safe). API_URL is the API ORIGIN (SDK appends /api/projects/<slug>/...).
NEXT_PUBLIC_ORBITNEST_API_URL=https://api.orbitnest.io
NEXT_PUBLIC_ORBITNEST_PROJECT_SLUG=loan_tracker
NEXT_PUBLIC_ORBITNEST_ANON_KEY=

# Server-only — DO NOT prefix with NEXT_PUBLIC_. Full-access key; keep off the client.
ORBITNEST_SERVICE_ROLE_KEY=
